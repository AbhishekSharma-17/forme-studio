# Forme Studio — backend environment variables
# Copy to `.env` and fill in real values.

# --- Server ---
FORME_HOST=127.0.0.1
FORME_PORT=8002
FORME_LOG_LEVEL=info
FORME_CORS_ORIGINS=http://localhost:2002,http://127.0.0.1:2002

# --- Storage ---
# Absolute path to the workspaces root. Each workspace lives in its own subdir.
FORME_WORKSPACES_DIR=/Users/abhisheksharma/Documents/Genaiprotos/Developer/forme-studio/workspaces
FORME_DB_PATH=/Users/abhisheksharma/Documents/Genaiprotos/Developer/forme-studio/forme.db

# --- AI providers ---
# OPENAI_API_KEY=sk-...
# VECTORIZER_AI_API_ID=
# VECTORIZER_AI_API_KEY=

# --- Provider selection (fallback is NEVER auto-invoked) ---
# Vectorizer: 'vectorizer_ai' | 'inkscape_potrace'
FORME_VECTORIZER_PROVIDER=vectorizer_ai
FORME_VECTORIZER_FALLBACK=inkscape_potrace
# vectorizer.ai billing mode: production (1 credit) | test (0.1 credit, watermark) | preview (free, low-res).
FORME_VECTORIZER_AI_MODE=production
FORME_VECTORIZER_TIMEOUT_S=180

FORME_INKSCAPE_PATH=/opt/homebrew/bin/inkscape
FORME_UNICONVERTOR_PATH=/opt/homebrew/bin/uniconvertor

# --- CDR export (slice 7) ---------------------------------------------
# Master switch — off by default (CDR is niche + neither provider is
# trivial to install). Flip on in Settings once you have UniConvertor
# installed or a CloudConvert key.
FORME_CDR_ENABLED=false
# Primary: 'cloudconvert' (paid) | 'uniconvertor' (free, local)
# Inkscape doesn't export CDR — these are the two real paths.
FORME_CDR_PROVIDER=cloudconvert
FORME_CDR_FALLBACK=uniconvertor
FORME_CDR_TIMEOUT_S=180

# CloudConvert API tokens (JWTs from https://cloudconvert.com/dashboard/api/v2/keys).
# Keep BOTH slots: sandbox keys 401 against the live host and vice-versa,
# so Forme picks one based on FORME_CLOUDCONVERT_SANDBOX. Toggle from the
# Settings dashboard to swap.
# CLOUDCONVERT_API_KEY=                # live key  → counts against your free 10/day or paid plan
# CLOUDCONVERT_SANDBOX_API_KEY=        # sandbox key → free, watermarked output

# True = sandbox host (api.sandbox.cloudconvert.com, free, watermarked).
# False = live host (api.cloudconvert.com, real output, free 10/day + pay-as-you-go).
# Newcomers: keep `true`, paste the sandbox key, flip in dashboard for live.
FORME_CLOUDCONVERT_SANDBOX=true

# OCR — Tesseract runs inside the unified analyze pipeline. Auto-detected;
# point FORME_TESSERACT_CMD at the binary if it's not already on PATH.
FORME_TESSERACT_CMD=tesseract
FORME_TESSERACT_LANG=eng

# Print PDF/X-4 — CMYK ICC profile used as the PDF output intent.
FORME_PRINT_ICC_PATH=/System/Library/ColorSync/Profiles/Generic CMYK Profile.icc
FORME_PRINT_ICC_NAME=Generic CMYK

# --- Models ---
FORME_OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21

# --- Pricing ---
# Optional markup applied to the OpenAI bill before showing it to the end user.
# 0 means we report the provider's exact cost.
FORME_PRICING_MARKUP_PERCENT=0
FORME_IMAGE_TIMEOUT_S=180
